{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/tmdb",
      "destination": "/api/tmdb.js"
    },
    {
      "source": "/api/watchmode",
      "destination": "/api/watchmode.js"
    },
    {
      "source": "/api/omdb",
      "destination": "/api/omdb.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS"
        }
      ]
    }
  ]
}
